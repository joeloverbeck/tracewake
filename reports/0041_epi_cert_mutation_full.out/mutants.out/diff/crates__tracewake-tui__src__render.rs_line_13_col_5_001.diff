 pub fn render_debug_overlay(view: &EmbodiedViewModel) -> String {
     let mut lines = Vec::new();
     if !view.debug_available {
         return lines.join("\n");
     }
     lines.push(format!("{}: Embodied Overlay", DEBUG_TOKENS[0]));
